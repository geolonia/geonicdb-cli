{
  "name": "@geolonia/geonicdb-cli",
  "version": "0.1.0",
  "description": "CLI tool for GeonicDB - FIWARE Orion compatible Context Broker",
  "type": "module",
  "bin": {
    "gdb": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "geonicdb",
    "fiware",
    "orion",
    "ngsi",
    "ngsiv2",
    "ngsi-ld",
    "context-broker",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "eslint": "^9.19.0",
    "@eslint/js": "^9.19.0",
    "typescript-eslint": "^8.22.0",
    "typescript": "^5.7.3",
    "tsup": "^8.3.6",
    "vitest": "^3.0.5",
    "prettier": "^3.4.2"
  }
}
